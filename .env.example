# Resend (https://resend.com) — para que el formulario de contacto envíe correos reales
# Si está vacío, el formulario funciona pero solo loggea en consola (modo dev/preview)
RESEND_API_KEY=

# Email destino donde llegan los leads
CONTACT_TO_EMAIL=

# Email "from" verificado en Resend (necesita dominio verificado)
CONTACT_FROM_EMAIL=
